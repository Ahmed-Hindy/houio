{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-msvc-debug",
      "displayName": "Windows MSVC Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-msvc-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "HOUIO_BUILD_TESTS": "ON",
        "HOUIO_BUILD_EXAMPLES": "ON"
      }
    },
    {
      "name": "windows-msvc-release",
      "displayName": "Windows MSVC Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-msvc-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "HOUIO_BUILD_TESTS": "ON",
        "HOUIO_BUILD_EXAMPLES": "ON"
      }
    },
    {
      "name": "windows-msvc-werror",
      "displayName": "Windows MSVC Warnings as Errors",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-msvc-werror",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "HOUIO_BUILD_TESTS": "ON",
        "HOUIO_BUILD_EXAMPLES": "ON",
        "HOUIO_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "windows-msvc-asan",
      "displayName": "Windows MSVC AddressSanitizer",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-msvc-asan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "HOUIO_BUILD_TESTS": "ON",
        "HOUIO_BUILD_EXAMPLES": "ON",
        "HOUIO_ENABLE_ADDRESS_SANITIZER": "ON"
      }
    },
    {
      "name": "linux-gcc-release",
      "displayName": "Linux GCC Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-gcc-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "HOUIO_BUILD_TESTS": "ON",
        "HOUIO_BUILD_EXAMPLES": "ON"
      }
    },
    {
      "name": "linux-gcc-ubsan",
      "displayName": "Linux GCC UndefinedBehaviorSanitizer",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-gcc-ubsan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "HOUIO_BUILD_TESTS": "ON",
        "HOUIO_BUILD_EXAMPLES": "ON",
        "HOUIO_ENABLE_UNDEFINED_SANITIZER": "ON"
      }
    },
    {
      "name": "linux-clang-fuzzer",
      "displayName": "Linux Clang Parser Fuzzer",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-clang-fuzzer",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_CXX_COMPILER": "clang++",
        "HOUIO_BUILD_TESTS": "OFF",
        "HOUIO_BUILD_EXAMPLES": "OFF",
        "HOUIO_BUILD_TOOLS": "OFF",
        "HOUIO_BUILD_FUZZ_TARGETS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-msvc-debug",
      "configurePreset": "windows-msvc-debug"
    },
    {
      "name": "windows-msvc-release",
      "configurePreset": "windows-msvc-release"
    },
    {
      "name": "windows-msvc-werror",
      "configurePreset": "windows-msvc-werror"
    },
    {
      "name": "windows-msvc-asan",
      "configurePreset": "windows-msvc-asan"
    },
    {
      "name": "linux-gcc-release",
      "configurePreset": "linux-gcc-release"
    },
    {
      "name": "linux-gcc-ubsan",
      "configurePreset": "linux-gcc-ubsan"
    },
    {
      "name": "linux-clang-fuzzer",
      "configurePreset": "linux-clang-fuzzer",
      "targets": [
        "houio_fuzz_parser"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "windows-msvc-debug",
      "configurePreset": "windows-msvc-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-msvc-release",
      "configurePreset": "windows-msvc-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-msvc-werror",
      "configurePreset": "windows-msvc-werror",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-msvc-asan",
      "configurePreset": "windows-msvc-asan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-gcc-release",
      "configurePreset": "linux-gcc-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-gcc-ubsan",
      "configurePreset": "linux-gcc-ubsan",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
